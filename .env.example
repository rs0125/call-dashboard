# ---- Supabase Postgres (SAME database as the Go exotel-call-service) ----
# Runtime connection for serverless/Vercel: the TRANSACTION pooler (port 6543).
# pgbouncer=true disables prepared statements (required behind the pooler);
# connection_limit caps concurrent connections per serverless instance. The
# Prisma client is a singleton shared across concurrent SSR requests, so =1
# serializes them and can trip P2024 pool-timeouts under load; 5 is safe behind
# the transaction pooler for a low-traffic internal tool.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&sslmode=require"

# Direct / session pooler (port 5432) — used ONLY for `prisma db pull`
# (introspection). Never used on the serverless hot path.
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Hide calls to/from these employees (by email, comma-separated) from every
# dashboard view — suppresses internal test traffic. Empty = hide nothing.
# DASHBOARD_BLOCKED_EMPLOYEE_EMAILS=name@example.com,other@example.com

# ---- Google OAuth 2.0 (hand-rolled auth-code flow; see src/lib/auth.ts) ----
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorized redirect URI must EXACTLY equal GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev:  http://localhost:3000/api/auth/google/callback
# Production: https://<your-vercel-domain>/api/auth/google/callback
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Who may sign in is controlled by the Supabase table `call_dashboard_whitelist`
# (email + name + is_active), NOT an env var. See prisma/whitelist.sql.
