generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model assignments {
  id                BigInt    @id @default(autoincrement())
  customer_phone    String    @unique(map: "idx_assignments_customer_phone")
  contact_id        BigInt
  last_contacted_at DateTime? @db.Timestamptz(6)
  created_at        DateTime? @db.Timestamptz(6)
  updated_at        DateTime? @db.Timestamptz(6)
  contacts          contacts  @relation(fields: [contact_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_assignments_contact")

  @@index([contact_id], map: "idx_assignments_contact_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model calls {
  id                         BigInt    @id @default(autoincrement())
  exotel_sid                 String    @unique(map: "idx_calls_exotel_s_id")
  from_number                String?
  to_number                  String?
  exophone                   String?
  direction                  String?
  status                     String?
  start_time                 DateTime? @db.Timestamptz(6)
  end_time                   DateTime? @db.Timestamptz(6)
  duration                   BigInt?
  conversation_duration      BigInt?
  price                      Decimal?  @db.Decimal
  recording_url              String?
  assigned_contact_id        BigInt?
  created_at                 DateTime? @db.Timestamptz(6)
  updated_at                 DateTime? @db.Timestamptz(6)
  leg1_status                String?
  leg2_status                String?
  leg1_duration              BigInt?
  leg2_duration              BigInt?
  recording_r2_key           String?
  recording_archived_at      DateTime? @db.Timestamptz(6)
  recording_archive_attempts BigInt?
  recording_archive_error    String?
  transcript                 Json?     @db.JsonB
  contacts                   contacts? @relation(fields: [assigned_contact_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_calls_assigned_contact")

  @@index([assigned_contact_id], map: "idx_calls_assigned_contact_id")
  @@index([from_number], map: "idx_calls_from_number")
  @@index([recording_r2_key], map: "idx_calls_recording_r2_key")
  @@index([status], map: "idx_calls_status")
  @@index([to_number], map: "idx_calls_to_number")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contacts {
  id                BigInt        @id @default(autoincrement())
  name              String?
  phone             String        @unique(map: "idx_contacts_phone")
  role              String?
  is_first_touch    Boolean?
  fallback_priority BigInt?
  active            Boolean?
  created_at        DateTime?     @db.Timestamptz(6)
  updated_at        DateTime?     @db.Timestamptz(6)
  phone_key         String?
  assignments       assignments[]
  calls             calls[]

  @@index([active], map: "idx_contacts_active")
  @@index([fallback_priority], map: "idx_contacts_fallback_priority")
  @@index([is_first_touch], map: "idx_contacts_is_first_touch")
  @@index([phone_key], map: "idx_contacts_phone_key")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model employees {
  id               BigInt             @id
  name             String?
  email            String?
  is_active        Boolean            @default(true)
  twenty_user_id   String?
  emp_id           String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  employee_numbers employee_numbers[]

  @@index([email], map: "idx_employees_email")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model employee_numbers {
  id           BigInt    @id @default(autoincrement())
  employee_id  BigInt
  phone_number String
  is_primary   Boolean   @default(false)
  is_active    Boolean   @default(true)
  label        String?
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  phone_key    String?   @unique(map: "uq_employee_numbers_phone_key")
  employees    employees @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([employee_id], map: "idx_employee_numbers_employee_id")
}
